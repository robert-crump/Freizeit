<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.drawerlayout.widget.DrawerLayout
        android:id="@+id/drawerLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/background_gray">

            <com.google.android.material.appbar.AppBarLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.appbar.MaterialToolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="?attr/actionBarSize"
                    style="@style/ToolbarStyle"
                    app:title="@string/app_name"
                    app:navigationIcon="@drawable/ic_menu"
                    app:menu="@menu/menu_main" />

            </com.google.android.material.appbar.AppBarLayout>

            <!-- Fester Header mit Standort, Überschrift, Chips und Toggle -->
            <LinearLayout
                android:id="@+id/headerContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/background_gray">

                <!-- Standort mit Progress Icon -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/locationText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/location_loading"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:drawableStart="@drawable/ic_location"
                        android:drawablePadding="6dp"
                        app:drawableTint="@color/text_secondary" />

                    <ProgressBar
                        android:id="@+id/locationProgress"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="8dp"
                        android:indeterminateTint="@color/turquoise_primary"
                        android:visibility="visible" />

                </LinearLayout>

                <!-- Aktivitäten in der Nähe Überschrift -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nearby_activities"
                    android:textSize="20sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="16dp" />

                <!-- Filter Chips -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="16dp"
                    android:orientation="horizontal">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/filterIndoorChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/activity_indoor"
                        android:layout_marginEnd="8dp"
                        style="@style/Widget.Material3.Chip.Filter"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/turquoise_primary"
                        app:chipStrokeWidth="1dp"
                        android:textColor="@color/chip_text_selector"
                        app:checkedIcon="@drawable/ic_check"
                        app:checkedIconTint="@color/white"
                        android:checkable="true"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/filterOutdoorChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/activity_outdoor"
                        style="@style/Widget.Material3.Chip.Filter"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/turquoise_primary"
                        app:chipStrokeWidth="1dp"
                        android:textColor="@color/chip_text_selector"
                        app:checkedIcon="@drawable/ic_check"
                        app:checkedIconTint="@color/white"
                        android:checkable="true"
                        android:checked="true" />

                </LinearLayout>

                <!-- Toggle: Listenansicht / Kartenansicht -->
                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/viewModeToggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="12dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <Button
                        android:id="@+id/listViewButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/view_list"
                        android:textSize="14sp"
                        style="?attr/materialButtonOutlinedStyle" />

                    <Button
                        android:id="@+id/mapViewButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/view_map"
                        android:textSize="14sp"
                        style="?attr/materialButtonOutlinedStyle" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

            </LinearLayout>

            <!-- Container für beide Ansichten mit layout_weight -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <!-- Listenansicht Container -->
                <androidx.core.widget.NestedScrollView
                    android:id="@+id/listViewContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- 5. Tagesempfehlung -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/recommendationCard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="16dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="4dp"
                            app:cardBackgroundColor="@color/white"
                            android:visibility="gone">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="16dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/recommendation_of_day"
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/turquoise_primary"
                                        android:layout_marginBottom="8dp"
                                        android:layout_marginEnd="40dp" />

                                    <androidx.recyclerview.widget.RecyclerView
                                        android:id="@+id/recommendationRecyclerView"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content" />

                                </LinearLayout>

                                <ImageView
                                    android:id="@+id/closeRecommendation"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:layout_gravity="top|end"
                                    android:layout_margin="8dp"
                                    android:src="@drawable/ic_close"
                                    android:padding="6dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:contentDescription="Close recommendation"
                                    app:tint="@color/text_secondary" />

                            </FrameLayout>

                        </com.google.android.material.card.MaterialCardView>

                        <!-- 6. Alle Aktivitäten Liste -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/activitiesRecyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="16dp"
                            android:paddingBottom="80dp"
                            android:clipToPadding="false" />

                        <!-- Empty State -->
                        <LinearLayout
                            android:id="@+id/emptyState"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="32dp"
                            android:visibility="gone">

                            <ImageView
                                android:layout_width="96dp"
                                android:layout_height="96dp"
                                android:src="@drawable/ic_all"
                                android:alpha="0.3"
                                app:tint="@color/text_secondary"
                                android:contentDescription="No activities" />

                            <TextView
                                android:id="@+id/emptyStateText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/no_activities"
                                android:textSize="16sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="16dp"
                                android:gravity="center" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.core.widget.NestedScrollView>

                <!-- Kartenansicht -->
                <FrameLayout
                    android:id="@+id/mapViewContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone">

                    <org.osmdroid.views.MapView
                        android:id="@+id/mapView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <!-- Karten Detail CardView (unten eingeblendet) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/mapDetailCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_margin="16dp"
                        android:visibility="gone"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="8dp"
                        app:cardBackgroundColor="@color/white">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="16dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <!-- Kategorie-Icon -->
                                <ImageView
                                    android:id="@+id/mapDetailCategoryIcon"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:contentDescription="Category Icon"
                                    app:tint="@android:color/black" />

                                <!-- Vertikales LinearLayout mit Name und Details -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="12dp"
                                    android:layout_marginEnd="40dp"
                                    android:orientation="vertical">

                                    <!-- Name der Aktivität -->
                                    <TextView
                                        android:id="@+id/mapDetailActivityName"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:textSize="16sp"
                                        android:textColor="@color/text_primary"
                                        android:textStyle="bold"
                                        android:maxLines="2"
                                        android:ellipsize="end" />

                                    <!-- Kategorie | Typ | Distanz -->
                                    <TextView
                                        android:id="@+id/mapDetailActivityDetails"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="2dp"
                                        android:textSize="12sp"
                                        android:textColor="@color/text_secondary"
                                        android:maxLines="1"
                                        android:ellipsize="end" />

                                </LinearLayout>

                                <!-- Maps Icon -->
                                <ImageView
                                    android:id="@+id/mapDetailMapsIcon"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/ic_map"
                                    android:contentDescription="Open in Maps"
                                    android:padding="4dp"
                                    app:tint="@color/turquoise_primary"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:background="?attr/selectableItemBackgroundBorderless" />

                            </LinearLayout>

                            <!-- X Button zum Schließen -->
                            <ImageView
                                android:id="@+id/mapDetailClose"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="top|end"
                                android:layout_margin="8dp"
                                android:src="@drawable/ic_close"
                                android:padding="6dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Close detail"
                                app:tint="@color/text_secondary" />

                        </FrameLayout>

                    </com.google.android.material.card.MaterialCardView>

                </FrameLayout>

            </FrameLayout>

        </LinearLayout>

        <!-- Navigation Drawer (Kategorien) -->
        <com.google.android.material.navigation.NavigationView
            android:id="@+id/navigationView"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            app:headerLayout="@layout/nav_header"
            app:menu="@menu/menu_drawer" />

    </androidx.drawerlayout.widget.DrawerLayout>

    <!-- FAB als Overlay -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_add"
        android:contentDescription="Add activity"
        app:tint="@color/white"
        app:backgroundTint="@color/turquoise_primary" />

</FrameLayout>