<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Freizeit" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/turquoise_primary</item>
        <item name="colorPrimaryVariant">@color/turquoise_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/turquoise_accent</item>
        <item name="colorSecondaryVariant">@color/turquoise_primary_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorSurface">@color/white</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <item name="android:statusBarColor">@color/turquoise_primary_dark</item>

        <!-- White toolbar icons -->
        <item name="colorControlNormal">@color/white</item>

        <!-- Overflow menu below toolbar -->
        <item name="actionOverflowMenuStyle">@style/OverflowMenuStyle</item>
    </style>

    <style name="Theme.Freizeit" parent="Base.Theme.Freizeit" />

    <!-- Toolbar Style -->
    <style name="ToolbarStyle" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/turquoise_primary</item>
        <item name="titleTextColor">@color/white</item>
        <item name="android:elevation">4dp</item>
        <item name="actionOverflowButtonStyle">@style/OverflowButtonStyle</item>
    </style>

    <!-- Overflow button (three dots) -->
    <style name="OverflowButtonStyle" parent="Widget.AppCompat.ActionButton.Overflow">
        <item name="android:tint">@color/white</item>
    </style>

    <!-- Overflow menu style -->
    <style name="OverflowMenuStyle" parent="Widget.AppCompat.PopupMenu.Overflow">
        <item name="android:dropDownVerticalOffset">4dp</item>
        <item name="android:dropDownHorizontalOffset">0dp</item>
        <item name="overlapAnchor">false</item>
    </style>

    <!-- Card Style -->
    <style name="CardViewStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Category Card Style -->
    <style name="CategoryCardStyle" parent="CardViewStyle">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- Button Style -->
    <style name="ButtonStyle" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/turquoise_primary</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Chip Style -->
    <style name="ChipStyle" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/turquoise_primary_light</item>
        <item name="chipStrokeColor">@color/turquoise_primary</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

    <!-- Dialog theme with turquoise radio buttons -->
    <style name="AlertDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorControlActivated">@color/turquoise_primary</item>
        <item name="colorControlNormal">@color/turquoise_primary</item>
    </style>
</resources>